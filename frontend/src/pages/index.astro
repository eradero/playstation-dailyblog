---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es-AR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 96px 24px;
				margin-bottom: 0;
			}
			.hero-content {
				max-width: 800px;
				margin: 0 auto;
			}
			.hero h1 {
				margin-bottom: 16px;
			}
			.hero p {
				font-size: 20px;
				color: rgba(255, 255, 255, 0.8);
				margin-bottom: 32px;
			}
			
			.news-section {
				padding: 64px 0;
			}
			.news-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 24px;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			
			/* Make first post span wider if wanted, but standard grid is safer for 3-surface */
			.news-grid li:first-child {
				grid-column: 1 / -1;
			}
			.news-grid li:first-child .ps-card {
				flex-direction: row;
			}
			.news-grid li:first-child .ps-card img {
				width: 60%;
				border-bottom: none;
				border-right: 1px solid var(--ps-divider);
			}
			.news-grid li:first-child .ps-card-content {
				width: 40%;
				justify-content: center;
			}
			.news-grid li:first-child .ps-card-title {
				font-size: 35px;
			}
			
			.date-tag {
				font-size: 14px;
				color: var(--text-secondary);
				margin-bottom: 8px;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			
			@media (max-width: 768px) {
				.news-grid li:first-child .ps-card { flex-direction: column; }
				.news-grid li:first-child .ps-card img { width: 100%; border-right: none; border-bottom: 1px solid var(--ps-divider); }
				.news-grid li:first-child .ps-card-content { width: 100%; }
				.news-grid li:first-child .ps-card-title { font-size: 24px; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="surface-dark dark-gradient hero">
				<div class="hero-content">
					<h1 class="display-xl">{SITE_TITLE}</h1>
					<p>{SITE_DESCRIPTION}</p>
					<a href="/blog" class="ps-btn">Explorar Noticias</a>
				</div>
			</section>
			
			<section class="surface-white news-section">
				<div class="container">
					<ul class="news-grid">
						{
							posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`} style="text-decoration: none;">
										<article class="ps-card">
											{post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
											<div class="ps-card-content">
												<div class="date-tag">
													<FormattedDate date={post.data.pubDate} />
												</div>
												<h4 class="ps-card-title">{post.data.title}</h4>
												<p style="color: var(--text-secondary); font-size: 16px; margin: 0;">{post.data.description || "Haz clic para leer el artículo completo..."}</p>
											</div>
										</article>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
